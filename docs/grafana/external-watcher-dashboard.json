{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for external watcher metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat"
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Registered Resources",
      "type": "stat",
      "targets": [
        {
          "expr": "kube_external_watcher_registered_resources{job=~\"$job\"}",
          "legendFormat": "Resources",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Poll Rate (per second)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(kube_external_watcher_poll_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "Polls/s",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Poll Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(kube_external_watcher_poll_total{job=~\"$job\", result=\"error\"}[$__rate_interval])) / sum(rate(kube_external_watcher_poll_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Drift Rate (per minute)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(kube_external_watcher_drift_detected_total{job=~\"$job\"}[$__rate_interval])) * 60",
          "legendFormat": "Drifts/min",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Avg Fetch Latency",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(kube_external_watcher_fetch_external_duration_seconds_sum{job=~\"$job\"}[$__rate_interval])) / sum(rate(kube_external_watcher_fetch_external_duration_seconds_count{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "Avg",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Fetch Errors (per minute)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(kube_external_watcher_fetch_external_errors_total{job=~\"$job\"}[$__rate_interval])) * 60",
          "legendFormat": "Errors/min",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Poll Activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*error.*" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Poll Rate by Result",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (result) (rate(kube_external_watcher_poll_total{job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{ result }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Poll Rate by Resource",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (namespace, name) (rate(kube_external_watcher_poll_total{job=~\"$job\", namespace=~\"$namespace\", name=~\"$resource\"}[$__rate_interval]))",
          "legendFormat": "{{ namespace }}/{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "External Fetch Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Fetch Latency (p50 / p90 / p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(kube_external_watcher_fetch_external_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(kube_external_watcher_fetch_external_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(kube_external_watcher_fetch_external_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Fetch Latency by Resource",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.90, sum by (le, namespace, name) (rate(kube_external_watcher_fetch_external_duration_seconds_bucket{job=~\"$job\", namespace=~\"$namespace\", name=~\"$resource\"}[$__rate_interval])))",
          "legendFormat": "{{ namespace }}/{{ name }} p90",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 22,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Fetch Errors by Resource",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (namespace, name) (rate(kube_external_watcher_fetch_external_errors_total{job=~\"$job\", namespace=~\"$namespace\", name=~\"$resource\"}[$__rate_interval]))",
          "legendFormat": "{{ namespace }}/{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Drift Detection",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal" }
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 30,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Drift Detected (rate)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (namespace, name) (rate(kube_external_watcher_drift_detected_total{job=~\"$job\", namespace=~\"$namespace\", name=~\"$resource\"}[$__rate_interval]))",
          "legendFormat": "{{ namespace }}/{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 31,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Drift Ratio (drifts / polls)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (namespace, name) (rate(kube_external_watcher_drift_detected_total{job=~\"$job\", namespace=~\"$namespace\", name=~\"$resource\"}[$__rate_interval])) / sum by (namespace, name) (rate(kube_external_watcher_poll_total{job=~\"$job\", namespace=~\"$namespace\", name=~\"$resource\"}[$__rate_interval]))",
          "legendFormat": "{{ namespace }}/{{ name }}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Resource Detail",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Error Rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.01 },
                    { "color": "red", "value": 0.05 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Fetch p90" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Drifts" },
            "properties": [
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
      "id": 40,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Error Rate" }]
      },
      "title": "Per-Resource Summary",
      "type": "table",
      "targets": [
        {
          "expr": "sum by (namespace, name) (rate(kube_external_watcher_poll_total{job=~\"$job\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Polls"
        },
        {
          "expr": "sum by (namespace, name) (rate(kube_external_watcher_poll_total{job=~\"$job\", result=\"error\"}[$__rate_interval])) / sum by (namespace, name) (rate(kube_external_watcher_poll_total{job=~\"$job\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "ErrorRate"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le, namespace, name) (rate(kube_external_watcher_fetch_external_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "FetchP90"
        },
        {
          "expr": "sum by (namespace, name) (increase(kube_external_watcher_drift_detected_total{job=~\"$job\"}[$__rate_interval]))",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "Drifts"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": { "byField": "namespace" }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #Polls": "Poll Rate",
              "Value #ErrorRate": "Error Rate",
              "Value #FetchP90": "Fetch p90",
              "Value #Drifts": "Drifts"
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kubernetes", "external-watcher", "controller-runtime"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "", "value": "" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(kube_external_watcher_poll_total, job)",
        "name": "job",
        "query": { "query": "label_values(kube_external_watcher_poll_total, job)", "refId": "A" },
        "regex": "",
        "type": "query",
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(kube_external_watcher_poll_total{job=~\"$job\"}, namespace)",
        "name": "namespace",
        "query": { "query": "label_values(kube_external_watcher_poll_total{job=~\"$job\"}, namespace)", "refId": "A" },
        "regex": "",
        "type": "query",
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(kube_external_watcher_poll_total{job=~\"$job\", namespace=~\"$namespace\"}, name)",
        "name": "resource",
        "query": { "query": "label_values(kube_external_watcher_poll_total{job=~\"$job\", namespace=~\"$namespace\"}, name)", "refId": "A" },
        "regex": "",
        "type": "query",
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kube External Watcher",
  "uid": "kube-external-watcher",
  "version": 1
}
